# Copia este archivo a ".env" y ajusta los valores.
#   cp .env.template .env   (Linux/Mac)
#   copy .env.template .env (Windows)

# ----- Aplicación -----
APP_ENV=development
APP_NAME=API Gestión de Transacciones PoliGran

# ----- Base de datos (MariaDB) -----
# DB_HOST debe ser "db" cuando se ejecuta con docker compose (nombre del servicio).
DB_HOST=db
DB_PORT=3306
DB_NAME=transacciones_db
DB_USER=root
DB_PASSWORD=1234
DB_ROOT_PASSWORD=1234
